rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "neelsoon64@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.code is string && data.code.size() > 0 && data.code.size() < 50 &&
             data.stockProvincia is number &&
             data.stockNacion is number;
    }
    
    function isValidMovement(data) {
      return data.productId is string &&
             data.type in ['entry', 'exit'] &&
             data.scope in ['provincia', 'nacion'] &&
             data.quantity is number && data.quantity > 0 &&
             data.documentType in ['boleta', 'remito', 'nota', 'otro'] &&
             data.date is timestamp;
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated(); // In a real app, maybe only admins
    }

    match /movements/{movementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMovement(request.resource.data);
      allow update, delete: if false; // Movements should be immutable for audit
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
